<div class="bg-light shadow-sm py-3 px-4 d-flex justify-content-between align-items-center mb-4">
  <div>
    <%= link_to "← Back to Home", root_path, class: "btn btn-outline-secondary" %>
  </div>
  <div class="fw-bold fs-4">Hairitege</div>
  <div>
    <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-danger" %>
  </div>
</div>

<div class="container py-5">
  <!-- Styled Heading -->
<h2 class="text-center mb-4" style="color: #28a745; font-family: 'Lobster', cursive; font-size: 2.5rem;">
  Your Clients
</h2>


  <% if @clients.any? %>
    <div class="row g-4">
      <% @clients.each do |client| %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card green-shadow h-100">
            <div class="card-body d-flex flex-column justify-content-between">
              <h5 class="card-title client-name">
  <i class="bi bi-person-circle"></i> <%= client.name %>
</h5>

              <p class="card-text text-muted"><%= client.email %></p>

              <!-- Styled Buttons -->
       <div class="mt-3 d-flex gap-2">
    <%= button_to "Open Mane-Vault", mane_vault_path(client_id: client.id), method: :get, class: "btn btn-outline-success btn-sm" %>
    <%= button_to "Remove Client", remove_client_path(client), 
          method: :delete, 
          data: { confirm: "Are you sure you want to remove this client?" }, 
          class: "btn btn-outline-danger btn-sm" %>
  </div>
</div>

        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted fs-5">You don’t have any clients yet. Add one below to get started!</p>
  <% end %>

  <div class="d-flex justify-content-center mt-5">
  <div class="card shadow-sm w-100 w-md-50 p-4" style="max-width: 500px;">
    <h4 class="text-center mb-4" style="color: #28a745; font-family: 'Lobster', cursive;">
      Add New Client
    </h4>

    <% if @new_client && @new_client.errors.any? %>
      <div class="alert alert-danger text-start">
        <h6>The following errors prevented the client from being saved:</h6>
        <ul class="mb-0">
          <% @new_client.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with scope: :user, url: create_client_stylists_path, method: :post, local: true do |f| %>
      <div class="mb-3">
        <%= f.text_field :name, placeholder: "Client Name", class: "form-control form-control-lg", required: true %>
      </div>

      <div class="mb-3">
        <%= f.email_field :email, placeholder: "Client Email", class: "form-control form-control-lg", required: true %>
      </div>

      <div class="mb-3">
        <%= f.password_field :password, placeholder: "Password", class: "form-control form-control-lg", required: true %>
      </div>

      <%= f.hidden_field :role, value: "client" %>

      <div class="d-grid">
        <%= f.submit "Add New Client", class: "btn btn-success btn-lg shadow-sm" %>
      </div>
    <% end %>
  </div>
</div>
