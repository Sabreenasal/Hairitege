<%= render "shared/navbar" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm rounded-3">
        <div class="card-body p-4">

          <h2 class="text-center mb-4 text-green font-lobster">
            Log in
          </h2>

          <%= simple_form_for(resource, as: :user, url: user_session_path, html: { method: :post }) do |f| %>
            <%= f.error_notification %>

            <div class="mb-3">
               <%= f.label :email, "Email", class: "form-label fw-semibold text-success" %>
          <%= f.input_field :email, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
             <%= f.label :password, "Password", class: "form-label fw-semibold text-success" %>
          <%= f.input_field :password, class: "form-control", required: true %>
            </div>

           <% if devise_mapping.rememberable? %>
  <div class="form-check mb-3">
    <%= f.check_box :remember_me, class: "form-check-input" %>
    <%= f.label :remember_me, "Remember me", class: "form-check-label" %>
  </div>
<% end %>


            <div class="d-grid">
              <%= f.button :submit, "Log in", class: "btn btn-success btn-lg rounded-pill" %>
            </div>
          <% end %>

          <div class="text-center mt-3">
            <%= render "devise/shared/links" %>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
