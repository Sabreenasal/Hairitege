<div class="bg-light shadow-sm py-3 px-4 d-flex justify-content-between align-items-center mb-4">
  <div>
    <%= link_to "← Back to Dashboard", stylist_dashboard_path, class: "btn btn-outline-secondary" %>
  </div>
  <div class="fw-bold fs-4 text-purple">Hairitege</div>
  <div>
    <%= link_to "Add Product", new_client_recommendation_path(@client), class: "btn btn-primary" %>
  </div>
</div>

<div class="container py-5">
  <h1 class="text-center mb-5 text-purple"><%= @client.name %>'s Mane Vault</h1>

  <% if @recommendations.any? %>
    <div class="row g-4">
      <% @recommendations.each do |rec| %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card shadow-sm h-100 border-purple">
            <div class="card-body d-flex flex-column justify-content-between">
              <h5 class="card-title text-purple"><%= rec.product.name %></h5>
              <p class="card-text text-muted"><%= rec.product.brand %></p>
              
              <% if rec.notes.present? %>
                <p class="card-text mt-2"><strong>Notes:</strong> <%= rec.notes %></p>
              <% else %>
                <p class="card-text text-muted mt-2">No notes added yet.</p>
              <% end %>

              <div class="mt-3">
                <%= link_to "Edit Notes", edit_recommendation_path(rec), class: "btn btn-outline-primary w-100" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted fs-5">No recommendations yet for this client. Add some to populate the Mane Vault!</p>
  <% end %>
</div>

<style>
  .text-purple {
    color: #6f42c1; 
  }

  .border-purple {
    border: 2px solid #6f42c1;
  }
</style>
