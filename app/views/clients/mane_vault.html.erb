<div class="bg-light shadow-sm py-3 px-4 d-flex align-items-center position-relative mb-4">

  <div class="position-absolute start-0">
    <%= link_to "← Back", current_user.stylist? ? stylist_dashboard_path : root_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="fw-bold fs-4 text-purple mx-auto text-center">
    Hairitege
  </div>

  <div class="position-absolute end-0 d-flex gap-2">
    <% if current_user.stylist? %>

      <%= link_to "Add Product", new_client_recommendation_path(@client), class: "btn btn-primary" %>
    <% else %>

      <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary" %>
    <% end %>
  </div>
</div>

<div class="container py-5">
  <h1 class="text-center mb-5 text-purple">
    <%= @client.name %>'s Mane Vault
  </h1>

  <% if @recommendations.any? %>
    <div class="row g-4">
      <% @recommendations.each do |rec| %>
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card shadow-sm h-100 border-purple p-3">
            <div class="card-body d-flex flex-column justify-content-between">

              <h5 class="card-title text-purple mb-2"><%= rec.product.name %></h5>
              <p class="card-text text-muted mb-3"><%= rec.product.brand %></p>

              <% if current_user.stylist? %>
                <!-- Update Notes Form -->
                <%= form_with model: rec, local: true do |f| %>
                  <%= hidden_field_tag :redirect_to, request.fullpath %>
                  <div class="mb-3">
                    <%= f.label :notes, "Notes" %>
                    <%= f.text_area :notes, class: "form-control", rows: 3, placeholder: "Add or edit notes..." %>
                  </div>
                  <%= f.submit "Save Notes", class: "btn btn-outline-primary w-100 mb-2" %>
                <% end %>

                <%= button_to "Unrecommend", client_recommendation_path(@client, rec),
                              method: :delete,
                              params: { redirect_to: request.fullpath },
                              data: { confirm: "Remove this product from the Mane Vault?" },
                              class: "btn btn-danger w-100" %>
              <% else %>

                <% if rec.notes.present? %>
                  <p class="card-text mt-2"><strong>Notes:</strong> <%= rec.notes %></p>
                <% else %>
                  <p class="card-text text-muted mt-2">No notes added yet.</p>
                <% end %>
              <% end %>

            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-center text-muted fs-5">No recommendations yet for this client. Add some to populate the Mane Vault!</p>
  <% end %>
</div>

<style>
  .text-purple { color: #6f42c1; }
  .border-purple { border: 2px solid #6f42c1; }
  .card-body { padding: 1.5rem; }
  .row.g-4 > .col-12 { margin-bottom: 1.5rem; }
</style>
