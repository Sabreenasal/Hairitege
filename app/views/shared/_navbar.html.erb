<div class="bg-light shadow-sm py-3 px-4 d-flex justify-content-between align-items-center mb-4">
  <div>
    <%= link_to "← Back", current_user.stylist? ? stylist_dashboard_path : root_path, class: "btn btn-outline-secondary" %>
  </div>

  <div class="fw-bold fs-4 text-success" style="font-family: 'Lobster', cursive;">
    Hairitege
  </div>

  <div class="d-flex gap-2">
    <% if current_user.stylist? %>
     
      <% if defined?(@client) %>
        <%= link_to "Add Product", new_client_recommendation_path(@client), class: "btn btn-primary" %>
      <% end %>
    <% else %>
      <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary" %>
    <% end %>
  </div>
</div>
